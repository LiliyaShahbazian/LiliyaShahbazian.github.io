---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/',       label: 'Home'  },
  { href: '/games',  label: 'Games' },
  { href: '/about',  label: 'About' },
];

const currentPath = Astro.url.pathname;
---
<nav class="sticky top-0 z-50 backdrop-blur-md bg-cream/80 dark:bg-charcoal/80 border-b border-pink-blush/40 dark:border-charcoal-soft">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between gap-4">
    <!-- Logo -->
    <a href="/" class="font-bold text-xl text-pink-hot hover:opacity-80 transition-opacity shrink-0">
      ✦ Liliya.dev
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'font-medium transition-colors hover:text-pink-hot',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-pink-hot border-b-2 border-pink-hot pb-0.5'
                : 'text-[var(--color-text)]',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <!-- Social links (desktop) -->
      <div class="hidden md:flex items-center gap-2">
        <a
          href="https://github.com/LiliyaShahbazian"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="p-2 rounded-full border border-pink-blush dark:border-charcoal-soft hover:bg-pink-blush/20 dark:hover:bg-charcoal-soft/40 transition-colors text-[var(--color-text)] hover:text-pink-hot"
        >
          <!-- GitHub icon -->
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/liliya-shahbazian"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="p-2 rounded-full border border-pink-blush dark:border-charcoal-soft hover:bg-pink-blush/20 dark:hover:bg-charcoal-soft/40 transition-colors text-[var(--color-text)] hover:text-pink-hot"
        >
          <!-- LinkedIn icon -->
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
      </div>

      <ThemeToggle />

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        aria-label="Toggle mobile menu"
        class="md:hidden p-2 rounded-full border border-pink-blush/50 dark:border-charcoal-soft hover:bg-pink-blush/20 transition-colors text-[var(--color-text)]"
      >
        <svg id="menu-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-pink-blush/30 dark:border-charcoal-soft">
    <ul class="px-4 py-3 flex flex-col gap-3">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block py-2 font-medium transition-colors hover:text-pink-hot',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-pink-hot'
                : 'text-[var(--color-text)]',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-1 pb-2 flex items-center gap-3">
        <a
          href="https://github.com/LiliyaShahbazian"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 font-medium text-[var(--color-text)] hover:text-pink-hot transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/liliya-shahbazian"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 font-medium text-[var(--color-text)] hover:text-pink-hot transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          LinkedIn
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('menu-icon-open')!;
  const iconClose = document.getElementById('menu-icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
  });
</script>
