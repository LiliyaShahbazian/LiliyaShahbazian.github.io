---
import SparkleDecor from './SparkleDecor.astro';
---
<section class="relative overflow-hidden min-h-[85vh] flex items-center justify-center bg-hero-light dark:bg-hero-dark">
  <!-- Decorative sparkles -->
  <SparkleDecor class="top-12 left-12" size="lg" delay="0s" />
  <SparkleDecor class="top-24 right-24" size="md" delay="0.6s" />
  <SparkleDecor class="bottom-20 left-1/4" size="sm" delay="1.2s" />
  <SparkleDecor class="top-1/3 right-12" size="sm" delay="0.9s" />
  <SparkleDecor class="bottom-32 right-1/3" size="lg" delay="0.3s" />

  <!-- Soft background blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-32 -left-32 w-96 h-96 rounded-full bg-pink-blush/20 dark:bg-pink-deep/10 blur-3xl"></div>
    <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full bg-lavender/20 dark:bg-lavender/10 blur-3xl"></div>
  </div>

  <div class="relative text-center px-4 max-w-3xl mx-auto z-10">
    <p class="text-pink-rose dark:text-pink-blush font-medium mb-4 tracking-widest uppercase text-sm">
      Unity Game Developer
    </p>
    <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-hot via-lavender to-pink-deep">
        Liliya Shahbazian
      </span>
    </h1>
    <p class="text-lg md:text-xl text-[var(--color-text-muted)] mb-10 max-w-xl mx-auto leading-relaxed">
      Crafting delightful browser games with Unity — from physics puzzles to arcade adventures.
      All playable right here, no download needed.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a
        href="/games"
        class="px-8 py-3 bg-pink-hot text-white font-semibold rounded-full hover:bg-pink-deep transition-colors shadow-lg shadow-pink-hot/30 hover:shadow-pink-deep/30"
      >
        View Games ✦
      </a>
      <a
        href="/about"
        class="px-8 py-3 border-2 border-pink-hot text-pink-hot font-semibold rounded-full hover:bg-pink-hot hover:text-white transition-colors"
      >
        About Me
      </a>
    </div>
  </div>
</section>
