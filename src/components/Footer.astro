---
const year = new Date().getFullYear();
---
<footer class="border-t border-pink-blush/30 dark:border-charcoal-soft mt-auto py-8">
  <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-[var(--color-text-muted)]">
    <p class="font-medium">✦ Liliya Shahbazian — Unity Game Developer</p>
    <div class="flex gap-6">
      <a
        href="https://github.com/LiliyaShahbazian"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-pink-hot transition-colors"
      >GitHub</a>
      <a
        href="https://linkedin.com/in/liliya-shahbazian"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-pink-hot transition-colors"
      >LinkedIn</a>
    </div>
    <p>&copy; {year}</p>
  </div>
</footer>
