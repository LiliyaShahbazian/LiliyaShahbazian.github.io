---
import BaseLayout from '../layouts/BaseLayout.astro';
import SparkleDecor from '../components/SparkleDecor.astro';
---
<BaseLayout title="About" description="About Liliya Shahbazian — Unity game developer">
  <div class="max-w-3xl mx-auto px-4 py-16 relative">
    <SparkleDecor class="-top-2 right-8" size="lg" delay="0s" />
    <SparkleDecor class="top-1/3 -left-2 hidden md:block" size="sm" delay="0.7s" />
    <SparkleDecor class="bottom-20 right-4" size="md" delay="1.4s" />

    <!-- Heading -->
    <h1 class="text-5xl md:text-6xl font-bold mb-2 text-[var(--color-text)]">
      Hi, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-hot to-lavender">Liliya</span> ✦
    </h1>
    <p class="text-pink-rose dark:text-pink-blush font-medium mb-12 text-lg tracking-wide">
      Unity Game Developer
    </p>

    <!-- Bio content — replace with your real information -->
    <div class="space-y-6 text-[var(--color-text)] leading-relaxed">
      <p class="text-lg">
        I'm a Unity game developer passionate about creating polished, engaging experiences
        that bring joy to players. I specialize in WebGL games that run directly in the browser —
        no downloads, no barriers, just fun.
      </p>
      <p>
        My projects focus on tight, satisfying gameplay loops — from physics-based puzzles to
        arcade-style action games. I love the challenge of making something that feels great to
        play from the very first moment.
      </p>

      <!-- Skills -->
      <div class="pt-4">
        <h2 class="text-2xl font-bold text-pink-hot mb-4">Skills</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {[
            'Unity (C#)',
            'WebGL build pipeline',
            'Game & level design',
            'Physics & animation',
            'UI/UX for games',
            'Shader Graph basics',
          ].map(skill => (
            <li class="flex items-center gap-2 text-[var(--color-text)]">
              <span class="text-pink-hot text-sm">✦</span>
              {skill}
            </li>
          ))}
        </ul>
      </div>

      <!-- Currently working on -->
      <div class="pt-4">
        <h2 class="text-2xl font-bold text-pink-hot mb-4">Currently Working On</h2>
        <p>
          More games! Check back soon for new additions to the collection.
        </p>
      </div>

      <!-- Contact -->
      <div class="pt-4">
        <h2 class="text-2xl font-bold text-pink-hot mb-4">Get In Touch</h2>
        <p>
          Found a bug? Want to collaborate? Feel free to reach out via
          <a href="https://github.com/LiliyaShahbazian" target="_blank" rel="noopener noreferrer" class="text-pink-hot hover:text-pink-deep transition-colors font-medium">GitHub</a>.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
