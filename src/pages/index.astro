---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import GameCard from '../components/GameCard.astro';
import { getCollection } from 'astro:content';

const featuredGames = (await getCollection('games'))
  .filter(g => g.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---
<BaseLayout title="Home" description="Liliya Shahbazian — Unity Game Developer Portfolio">
  <Hero />

  {featuredGames.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 py-20">
      <div class="flex items-end justify-between mb-10 flex-wrap gap-4">
        <div>
          <h2 class="text-3xl font-bold text-[var(--color-text)]">
            Featured Games <span class="text-pink-hot">✦</span>
          </h2>
          <p class="text-[var(--color-text-muted)] mt-1">Play directly in your browser — no download needed</p>
        </div>
        <a
          href="/games"
          class="text-pink-hot font-medium hover:text-pink-deep transition-colors text-sm"
        >
          View all →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredGames.map(game => <GameCard game={game} />)}
      </div>
    </section>
  )}
</BaseLayout>
